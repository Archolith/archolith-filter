# archolith-filter — Environment-Variable Reference
# ==================================================
#
# Copy this file to `.env` and adjust as needed (e.g. for local development
# or to override defaults in CI). All variables are optional; when unset the
# defaults shown below apply (and are clamped by the bounds noted).
#
# Variables follow the naming convention ARCHOLITH_FILTER_<SECTION>_<FIELD>.
# Numeric values are clamped to [0, maximum] when a maximum is documented.
# Boolean values use 1/0.

# ─── Risk level ──────────────────────────────────────────────────────
# Determines the base preset applied for every unset category field.
# One of: low | balanced | high
#ARCHOLITH_FILTER_RISK_LEVEL=balanced

# ─── Generic (default category) ───────────────────────────────────────
#ARCHOLITH_FILTER_GENERIC_HEAD=20
#ARCHOLITH_FILTER_GENERIC_TAIL=30
#ARCHOLITH_FILTER_GENERIC_STACK_COLLAPSE_ENABLED=1
#ARCHOLITH_FILTER_GENERIC_STACK_COLLAPSE_MIN_FRAMES=3
#ARCHOLITH_FILTER_GENERIC_STACK_COLLAPSE_KEEP_APP=1

# ─── Test / build / lint / typecheck ──────────────────────────────────
#ARCHOLITH_FILTER_TEST_HEAD=10
#ARCHOLITH_FILTER_TEST_TAIL=40
#ARCHOLITH_FILTER_BUILD_HEAD=15
#ARCHOLITH_FILTER_BUILD_TAIL=25
#ARCHOLITH_FILTER_BUILD_SUMMARY_ENABLED=1
#ARCHOLITH_FILTER_LINT_HEAD=15
#ARCHOLITH_FILTER_LINT_TAIL=30
#ARCHOLITH_FILTER_TYPECHECK_HEAD=15
#ARCHOLITH_FILTER_TYPECHECK_TAIL=30

# ─── Git ──────────────────────────────────────────────────────────────
#ARCHOLITH_FILTER_GIT_DIFF_FILE_HEAD=8
#ARCHOLITH_FILTER_GIT_DIFF_TAIL=10
#ARCHOLITH_FILTER_GIT_LOG_HEAD=25
#ARCHOLITH_FILTER_GIT_LOG_TAIL=15
#ARCHOLITH_FILTER_GIT_STATUS_HEAD=50
#ARCHOLITH_FILTER_GIT_STATUS_TAIL=30
#ARCHOLITH_FILTER_GIT_STATUS_GROUP_ENABLED=1
#ARCHOLITH_FILTER_GIT_STATUS_GROUP_MAX=5

# ─── Log filtering ────────────────────────────────────────────────────
#ARCHOLITH_FILTER_LOG_HEAD=15
#ARCHOLITH_FILTER_LOG_TAIL=30
#ARCHOLITH_FILTER_LOG_MAX_DUPE=3

# ─── Filesystem listings ──────────────────────────────────────────────
#ARCHOLITH_FILTER_FS_MAX_ENTRIES=50
#ARCHOLITH_FILTER_FS_HEAD_LINES=20
#ARCHOLITH_FILTER_FS_TAIL_LINES=30
#ARCHOLITH_FILTER_FS_LSL_ABBREVIATE_ENABLED=1

# ─── Search ───────────────────────────────────────────────────────────
#ARCHOLITH_FILTER_SEARCH_MAX_MATCHES=5
#ARCHOLITH_FILTER_SEARCH_MAX_FILES=15
#ARCHOLITH_FILTER_SEARCH_HEAD_LINES=20
#ARCHOLITH_FILTER_SEARCH_TAIL_LINES=30
#ARCHOLITH_FILTER_SEARCH_HEADING_REFORMAT_ENABLED=1

# ─── JSON filtering (Strategy 1: structural caps) ─────────────────────
#ARCHOLITH_FILTER_JSON_MAX_KEYS=10
#ARCHOLITH_FILTER_JSON_MAX_ARRAY=5
#ARCHOLITH_FILTER_JSON_MAX_DEPTH=3
#ARCHOLITH_FILTER_JSON_MAX_VALUE_LEN=80

# ─── JSON CSV reshape (Strategy 2) ────────────────────────────────────
#ARCHOLITH_FILTER_JSON_CSV_ENABLED=1
#ARCHOLITH_FILTER_JSON_CSV_MIN_ROWS=3
#ARCHOLITH_FILTER_JSON_CSV_MAX_ROWS=20
#ARCHOLITH_FILTER_JSON_CSV_MAX_KEY_LEN=40
#ARCHOLITH_FILTER_JSON_CSV_FACTOR_ENABLED=1
#ARCHOLITH_FILTER_JSON_CSV_FACTOR_THRESHOLD=0.95
#ARCHOLITH_FILTER_JSON_CSV_FACTOR_MAX_COLS=10

# ─── JSON key=value reshape (Strategy 3) ──────────────────────────────
#ARCHOLITH_FILTER_JSON_KV_ENABLED=1
#ARCHOLITH_FILTER_JSON_KV_MIN_KEYS=3
#ARCHOLITH_FILTER_JSON_KV_MAX_KEYS=20

# ─── JSON dotted-key reshape (Strategy 4) ────────────────────────────
#ARCHOLITH_FILTER_JSON_DOTKEY_ENABLED=1
#ARCHOLITH_FILTER_JSON_DOTKEY_MAX_KEYS=30
#ARCHOLITH_FILTER_JSON_DOTKEY_MAX_DEPTH=2

# ─── read_file filter ────────────────────────────────────────────────
#ARCHOLITH_FILTER_READ_IMPORTS_COLLAPSE=1
#ARCHOLITH_FILTER_READ_BLANK_LINE_MAX=10
#ARCHOLITH_FILTER_READ_COMMENT_THRESHOLD=50
#ARCHOLITH_FILTER_READ_CSS_RULE_COLLAPSE=1
#ARCHOLITH_FILTER_READ_GENERATED_MIN_LINE_LEN=5000
#ARCHOLITH_FILTER_READ_GENERATED_MIN_RUN=50
#ARCHOLITH_FILTER_READ_LITERAL_THRESHOLD=100

# ─── Layer 0 toggles ─────────────────────────────────────────────────
#ARCHOLITH_FILTER_REDACT_ENABLED=1
#ARCHOLITH_FILTER_STRIP_THINKING_ENABLED=1
#ARCHOLITH_FILTER_NORMALIZE_PATHS_ENABLED=1
#ARCHOLITH_FILTER_BINARY_DETECTION_ENABLED=1
#ARCHOLITH_FILTER_OVERSIZED_GUARD_ENABLED=1
#ARCHOLITH_FILTER_OVERSIZED_MAX_CHARS=500000
#ARCHOLITH_FILTER_NORMALIZE_NOISE_ENABLED=1
#ARCHOLITH_FILTER_TABLE_WHITESPACE_MIN_ENABLED=1

# ─── Workspace root detection (paths.py) ────────────────────────────
# When set, occurrences of this path in tool output are normalised to
# placeholder tokens so the LLM sees relative paths instead of full
# machine paths. ARCHOLITH_RTK_WORKSPACE_ROOT is a back-compat alias.
#ARCHOLITH_FILTER_WORKSPACE_ROOT=/absolute/path/to/your/project
#ARCHOLITH_RTK_WORKSPACE_ROOT=/absolute/path/to/your/project
# Set to "off" to disable stripping of the workspace root prefix.
#ARCHOLITH_FILTER_STRIP_WORKSPACE_ROOT=

# ─── Optional token-counting accuracy ────────────────────────────────
# Installing tiktoken (archolith-filter[tokenizer]) enables accurate BPE
# token counts in shrink/truncate paths. Without it, the library falls back
# to a ~4 chars/token heuristic. See README.md for installation details.
